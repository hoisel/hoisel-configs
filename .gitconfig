[user]
    name = hoisel
    email = danielhoiselferraz@gmail.com
[core]
    editor = windsurf --wait
    autocrlf = input
[diff]
    tool = default-difftool
[difftool "default-difftool"]
    cmd = "windsurf --wait --diff "
[alias]
    ce = config --global --edit
    stash-staged = "stash push --staged -m \"staged\""
    cb = checkout -b
    co = checkout
    bb = switch -b
    b = switch
    s = status
    ss = status -s
    fa = fetch --all
    fap = fetch --all -p
    tg = tag -l --sort=v:refname
    rb = branch -D
    rtag = "!f(){ if [ -z \"$1\" ]; then echo \"Usage: git rtag <tag> | git rtag <remote> <tag>\" >&2; return 2; fi; if [ -z \"$2\" ]; then remote=origin; tag=\"$1\"; else remote=\"$1\"; tag=\"$2\"; fi; git tag -d \"$tag\" 2>/dev/null || true; git push \"$remote\" \":refs/tags/$tag\"; }; f"
    ignore = "!gi() { curl -sL https://www.toptal.com/developers/gitignore/api/$@ ;}; gi"
	prw = "!f() {\n  num=\"$1\";\n  remote=\"${2:-origin}\";\n  branch=\"pr-$num\";\n  dir=\"../pr-$num\";\n  git fetch \"$remote\" \"pull/$num/head:$branch\" &&\n  git worktree add \"$dir\" \"$branch\" &&\n  echo \"✅ Worktree para PR #$num criada em $dir\" &&\n  cd \"$dir\";\n}; f"
	prwrm = "!f() {\n  num=\"$1\";\n  dir=\"../pr-$num\";\n  git worktree remove \"$dir\" &&\n  git branch -D \"pr-$num\" &&\n  echo \"✅ Worktree PR #$num removida de $dir\";\n}; f"
[credential "https://github.com"]
    helper = !/usr/bin/gh auth git-credential
[credential "https://gist.github.com"]
    helper = !/usr/bin/gh auth git-credential
[credential "https://gitlab.com"]
    helper = !/usr/bin/glab auth git-credential
[credential "https://globalsysdev.visualstudio.com"]
    helper = store
[credential "https://dev.azure.com/gmill"]
    helper = store
[maintenance]
	auto = true
	repo = /home/hoisel/Dev/Professional/NameCoach/namecoach-fe